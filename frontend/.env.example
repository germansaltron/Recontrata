# API (vacío en prod: frontend y API comparten dominio)
VITE_API_URL=
# Auth mock para desarrollo/E2E (true = sin Clerk). En prod debe ir vacío/false.
VITE_AUTH_MOCK_ENABLED=
# Clerk: pk_test_... en desarrollo, pk_live_... en producción (ver BETA_SETUP.md).
VITE_CLERK_PUBLISHABLE_KEY=

# Observabilidad (opcional). DSN del proyecto Sentry de frontend. Vacío = desactivado.
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=production

# Canal de feedback del beta: URL de un formulario de Google o chat de WhatsApp.
# Si está vacío, el botón flotante "Feedback" no se muestra.
VITE_FEEDBACK_URL=
