# Backend
DEBUG=False
DATABASE_URL=postgresql://postgres:password@host:5432/postgres
CORS_ORIGINS=["https://faenascore-production.up.railway.app"]

# Auth (testing only — set both True + False for real launch with Clerk)
AUTH_MOCK_ENABLED=True
ALLOW_MOCK_IN_PROD=True
CLERK_SECRET_KEY=
CLERK_JWKS_URL=
CLERK_ISSUER=
CLERK_AUDIENCE=

# Pasarela de pago (Flow) — ver docs/PASARELA_PAGO_FLOW.md
# Sandbox: https://sandbox.flow.cl/api · Producción: https://www.flow.cl/api
FLOW_API_KEY=
FLOW_API_SECRET=
FLOW_API_BASE=https://sandbox.flow.cl/api
# planId generados una vez con: python scripts/flow_bootstrap_plans.py
FLOW_PLAN_ID_PRO_MONTHLY=
FLOW_PLAN_ID_PRO_ANNUAL=
FLOW_PLAN_ID_EMPRESA_MONTHLY=
FLOW_PLAN_ID_EMPRESA_ANNUAL=
FLOW_COUPON_FOUNDER=
BILLING_RETURN_URL=https://faenascore-production.up.railway.app/billing/return
FLOW_WEBHOOK_URL=https://faenascore-production.up.railway.app/api/v1/webhooks/flow

# Frontend (set in Railway build-time)
VITE_API_URL=/api/v1
VITE_CLERK_PUBLISHABLE_KEY=
