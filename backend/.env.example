APP_NAME=FaenaScore
DEBUG=true
DATABASE_URL=postgresql+asyncpg://faenascore:faenascore_dev@localhost:5432/faenascore
AUTH_MOCK_ENABLED=true
CLERK_SECRET_KEY=
CLERK_JWKS_URL=
CLERK_ISSUER=
CLERK_AUDIENCE=
CORS_ORIGINS=["http://localhost:5173"]
# Observabilidad (opcional). Pega el DSN del proyecto Sentry para activar el
# tracking de errores en prod. Vacío = desactivado (no-op).
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
